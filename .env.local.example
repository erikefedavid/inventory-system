# Copy this file to .env.local and fill in values for local development.
# .env.local is gitignored and never committed.

# MongoDB connection (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/stockpilot

# JWT signing secret (use at least 32 random characters in production)
JWT_SECRET=your-dev-secret-at-least-32-chars

# Issuer URL for JWT validation (must match your dev server origin)
NEXTAUTH_URL=http://localhost:3000
